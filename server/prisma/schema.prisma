generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(255)
  email           String           @unique @db.VarChar(255)
  password        String?          @db.VarChar(255)
  role            String           @default("user") @db.VarChar(255)
  authProvider    String           @default("local") @db.VarChar(255)

  user_progress   user_progress[]
}
model lessons {
  id             Int          @id @default(autoincrement())
  title          String       @db.VarChar(255)
  video_url      String       @db.VarChar(255)
  thumbnail_url  String       @db.VarChar(255)
  created_at     DateTime     @db.DateTime(0)
  subtitles      subtitles[]
}


model subtitles {
  id          Int       @id @default(autoincrement())
  lesson_id   Int
  start_time  String    @db.VarChar(255)
  end_time    String    @db.VarChar(255)
  full_text   String    @db.Text

  lesson      lessons   @relation(fields: [lesson_id], references: [id], onDelete: Cascade, map: "subtitles_ibfk_1")

  @@index([lesson_id], map: "lesson_id")
}



model roadmaps {
  level_id          Int       @id @default(autoincrement())
  level_name        String    @db.VarChar(255)
  description       String?   @db.Text
  
  days              days[]

  created_at        DateTime  @default(now()) @db.DateTime(0)
  updated_at        DateTime  @default(now()) @db.DateTime(0)
}


model days {
  day_id       Int         @id @default(autoincrement())
  roadmap_id   Int
  day_number   Int
  theme        String      @db.VarChar(255)
  description  String?     @db.Text
  condition    Int
  

  roadmap      roadmaps    @relation(fields: [roadmap_id], references: [level_id], onDelete: Cascade)
  activities   activities[]

  @@index([roadmap_id])

  created_at   DateTime    @default(now()) @db.DateTime(0)
  updated_at   DateTime    @default(now()) @db.DateTime(0)
}


model user_progress {
  progress_id   Int           @id @default(autoincrement())
  user_id       Int
  activity_id   Int?          // Một UserProgress thuộc về một Activity
  is_completed  Boolean     @default(false)
  time_spent    Int?
  completed_at  DateTime?
 

  user          users         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  activity      activities?   @relation(fields: [activity_id], references: [activity_id], onDelete: Cascade)

  @@index([user_id])
  @@index([activity_id])

  created_at    DateTime      @default(now()) @db.DateTime(0)
  updated_at    DateTime      @default(now()) @db.DateTime(0)
}


model activities {
  activity_id      Int         @id @default(autoincrement())
  day_id           Int?
  skill            String      @db.VarChar(100)
  point_of_ac      Int
  order_index      Int
  content          String?     @db.Text
  resources        Json?
  
  day              days?            @relation(fields: [day_id], references: [day_id], onDelete: Cascade)
  user_progress    user_progress[]  // Một Activity có thể có nhiều UserProgress

  @@index([day_id])

  created_at       DateTime    @default(now()) @db.DateTime(0)
  updated_at       DateTime    @default(now()) @db.DateTime(0)
}
